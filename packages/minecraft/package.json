{
  "name": "@opys/minecraft",
  "version": "0.1.24",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown lib/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
