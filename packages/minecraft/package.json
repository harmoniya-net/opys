    "test:int": "vitest run tests/integration --testTimeout=120000"
  },
  "dependencies": {
    "@opys/forgewrapper": "^0.1.24",
    "@opys/minecraft-vanilla": "^0.1.24",
    "@opys/forge": "^0.1.24",
    "@opys/neoforge": "^0.1.24",
    "@opys/fabric": "^0.1.24",
    "@opys/cleanroom": "^0.1.24",
    "@opys/lwjgl3ify": "^0.1.24",
    "@opys/authliberty": "^0.1.24",
    "@opys/curseforge": "^0.1.24",
    "@opys/modrinth": "^0.1.24",
    "@opys/bifrost": "^0.1.24",
    "@opys/minecraft-serverlist": "^0.1.24",
    "@opys/java": "^0.1.24",
    "@opys/dgpuj": "^0.1.24"
  },
  "devDependencies": {
    "@opys/core": "^0.1.24",
    "@opys/dev": "^0.1.24",
    "@opys/mojang": "^0.1.24",
    "tsdown": "*",
    "vitest": "*"
