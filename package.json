{
  "name": "unipack",
  "scripts": {
    "format": "prettier --write .",
    "build": "bun run --filter './*' build",
    "test": "bun run --filter './*' test",
    "test:int": "bun run --filter './*' test:int",
    "prepare": "husky"
  },
  "workspaces": [
    "rules",
    "minecraft"
  ],
  "devDependencies": {
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@types/bun": "^1.3.9",
    "effect": "^3.19.18",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,md}": "prettier --write"
  }
}
