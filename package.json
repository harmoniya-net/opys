{
  "name": "torba",
  "version": "1.0.13",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:int": "npm run test:int --workspaces --if-present",
    "prepare": "husky",
    "release": "node scripts/release.mjs"
  },
  "workspaces": [
    "mojang-rules",
    "core",
    "dev",
    "mojang",
    "minecraft",
    "java",
    "runtime",
    "cli",
    "crates/torba-core-napi",
    "crates/torba-runtime-napi"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.6",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,md}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  }
}
