{
  "name": "torba",
  "version": "1.0.4",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:int": "npm run test:int --workspaces --if-present",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "npm version --workspaces --include-workspace-root --no-git-tag-version",
    "release": "npm run build && changeset publish"
  },
  "workspaces": [
    "rules",
    "core",
    "mojang",
    "minecraft",
    "forge",
    "curseforge",
    "installer",
    "cli"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.17",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "1.0.1": "^1.0.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,md}": "prettier --write"
  }
}
