{
  "name": "opys",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:int": "npm run test:int --workspaces --if-present",
    "prepare": "husky",
    "release": "node scripts/release.mjs"
  },
  "workspaces": [
    "packages/mojang-rules",
    "packages/core",
    "packages/dev",
    "packages/mojang",
    "packages/minecraft-vanilla",
    "packages/forge",
    "packages/cleanroom",
    "packages/lwjgl3ify",
    "packages/authliberty",
    "packages/curseforge",
    "packages/bifrost",
    "packages/minecraft-serverlist",
    "packages/java",
    "packages/minecraft",
    "packages/runtime",
    "packages/cli",
    "crates/opys-core-napi",
    "crates/opys-runtime-napi"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.6",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,md}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  }
}
