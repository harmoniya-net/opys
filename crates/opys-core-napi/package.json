{
  "name": "@opys/core-binding",
  "version": "0.1.3",
  "private": true,
  "description": "napi-rs binary binding for @opys/core. Not consumed directly — re-exported by @opys/core.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "opys-core",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harmoniya-net/opys.git",
    "directory": "crates/opys-core-napi"
  }
}
